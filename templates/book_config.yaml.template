# book_config.yaml — generated by new-splinter.py on {created_date}
# Schema documented in the alpha-reader-toolkit's README and METHODOLOGY.

splinter:  # the orchestrator's term for "this project"; just a label
  slug: {slug}
  created: "{created_date}"

book:
  slug: {book_slug}
  title: "{title}"
  pen_name: "{pen_name}"
  manuscript_path: "manuscript/{manuscript_filename}"
  genre_hint: "{genre}"
  context_role: "{context_role}"
  is_complete: {is_complete}
  next_book_teaser: {next_book_teaser_yaml}
  q4_keep_reading_phrasing: {q4_phrasing_yaml}

{pass_b_section}

# Cost discipline (per pass; binding)
cost_cap_usd: {cost_cap}
per_persona_cost_halt_usd: 5.00

# Default models
default_model: "claude-sonnet-4-6"
opus_model: "claude-opus-4-7"
