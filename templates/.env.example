# Project-local environment overrides
# Copy this to .env and populate. .env is gitignored.

# Direct Anthropic API key from console.anthropic.com.
# Get one at: https://console.anthropic.com/
#
# Note: if you're launching this from inside a Claude Code shell that
# injects ANTHROPIC_API_KEY automatically, that injected key is OAuth-bound
# and returns 401 on direct SDK calls. Use a real direct API key here;
# python-dotenv will load this file with override=True before the SDK runs.
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
